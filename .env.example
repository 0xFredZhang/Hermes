# Hermes configuration — copy to .env (or run `make env`) and edit.
# Values are loaded by the Makefile and read by config.Load().

# Listen address (default 127.0.0.1:8080; loopback only)
HERMES_ADDR=127.0.0.1:8080

# SQLite database path (default hermes.db)
HERMES_DB_PATH=hermes.db

# Master key: base64-encoded 32 bytes. Generate one with `make gen-key`.
HERMES_MASTER_KEY=

# Login password (required — change this)
HERMES_LOGIN_PASSWORD=changeme

# Pulumi state backend (default file:///absolute/repo/path/data/pulumi-state).
# Supported forms: file:///absolute/path or s3://<bucket>/<optional-prefix>.
# Create the S3 bucket first when using a remote backend.
HERMES_PULUMI_BACKEND=

# Pulumi project name (default hermes)
HERMES_PULUMI_PROJECT=hermes

# Number of concurrent provisioning workers (default 2)
HERMES_WORKERS=2
